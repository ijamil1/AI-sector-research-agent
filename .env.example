# Provider-agnostic LangChain model identifiers.
# DeepSeek model IDs: https://api-docs.deepseek.com/quick_start/pricing
ORCHESTRATOR_MODEL=deepseek:deepseek-v4-pro
RESEARCHER_MODEL=deepseek:deepseek-v4-flash
RESEARCH_AGENT_TEMPERATURE=0

# Runtime research budgets enforced by ResearchLimitsMiddleware.
MAX_SEARCH_CALLS=8
MAX_TASK_CALLS=10
MAX_ORCHESTRATOR_MODEL_CALLS=30
MAX_RESEARCHER_MODEL_CALLS=30

# Required when using the default Tavily-backed web_search tool.
TAVILY_API_KEY=

# Provider key for the selected DeepSeek models.
DEEPSEEK_API_KEY=your-deepseek-api-key
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
