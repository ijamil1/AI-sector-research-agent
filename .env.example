# Provider-agnostic LangChain model identifier.
# Anthropic model IDs: https://docs.anthropic.com/en/docs/about-claude/models
RESEARCH_AGENT_MODEL=anthropic:claude-sonnet-4-20250514
RESEARCH_AGENT_TEMPERATURE=0

# Runtime research budgets enforced by ResearchLimitsMiddleware.
MAX_SEARCH_CALLS=8
MAX_TASK_CALLS=3
MAX_ORCHESTRATOR_MODEL_CALLS=6

# Required when using the default Tavily-backed web_search tool.
TAVILY_API_KEY=

# Provider key for the model selected in RESEARCH_AGENT_MODEL.
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
